#!/bin/bash
# Copies the selected tool's full source or definition to the X11 clipboard and primary selection
# Keywords: gt-yank, clipboard, xclip, copy source, yank code, copy function, copy alias, X11 clipboard
# gt-yank — copy the selected tool's source/definition to X11 CLIPBOARD + PRIMARY
# Called from gt via Ctrl-Y binding
# Scripts:   whole file
# Functions: the function body (start line → next line that starts with '}' )
# Aliases:   the single alias line

set -u

INDEX="${HOME}/.local/share/mytools/index.tsv"
row=$(printf '%s' "${1:-}" | sed 's/\x1b\[[0-9;]*m//g')
[ -z "$row" ] && exit 0

if ! command -v xclip >/dev/null 2>&1; then
  notify-send -t 2000 "gt-yank" "xclip not installed" 2>/dev/null || true
  exit 1
fi

type=$(printf '%s' "$row" | awk '{print $1}' | tr -d '[]')
name=$(printf '%s' "$row" | awk '{print $2}')
rec=$(awk -F'\t' -v t="$type" -v n="$name" '$1==t && $2==n {print; exit}' "$INDEX")
if [ -z "$rec" ]; then
  notify-send -t 2000 "gt-yank" "no record for $type/$name" 2>/dev/null || true
  exit 1
fi

path=$(printf '%s' "$rec" | awk -F'\t' '{print $3}')
file="${path%%:*}"
line=""
case "$path" in
  *:*) line="${path##*:}" ;;
esac

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

case "$type" in
  script)
    if [ -r "$file" ]; then
      cat "$file" > "$tmp"
    else
      echo "(unreadable: $file)" > "$tmp"
    fi
    ;;
  function)
    if [ -r "$file" ] && [ -n "$line" ]; then
      # copy from the function declaration line to the first lone closing brace
      awk -v start="$line" '
        NR==start { inside=1 }
        inside    { print }
        inside && NR>start && /^[[:space:]]*\}[[:space:]]*$/ { exit }
      ' "$file" > "$tmp"
    fi
    ;;
  alias)
    if [ -r "$file" ] && [ -n "$line" ]; then
      sed -n "${line}p" "$file" > "$tmp"
    fi
    ;;
  *)
    echo "(unknown type: $type)" > "$tmp"
    ;;
esac

# Copy to both CLIPBOARD (Ctrl-V) and PRIMARY (middle-click)
xclip -selection clipboard < "$tmp" 2>/dev/null
xclip -selection primary   < "$tmp" 2>/dev/null

bytes=$(wc -c < "$tmp")
lines=$(wc -l < "$tmp")
notify-send -t 2000 "gt-yank" "copied $type $name ($lines lines, $bytes bytes)" 2>/dev/null || true
