#!/bin/bash
# Opens the selected gt catalog entry in the user's editor, jumping to the correct line for functions and aliases
# Keywords: gt-edit, editor, open source, jump to line, edit script, edit function, fzf binding
# gt-edit — open the file for an fzf row in $EDITOR
# Called by gt via Ctrl-E binding

set -u

INDEX="${HOME}/.local/share/mytools/index.tsv"
row=$(printf '%s' "${1:-}" | sed 's/\x1b\[[0-9;]*m//g')
[ -z "$row" ] && exit 0

type=$(printf '%s' "$row" | awk '{print $1}' | tr -d '[]')
name=$(printf '%s' "$row" | awk '{print $2}')
rec=$(awk -F'\t' -v t="$type" -v n="$name" '$1==t && $2==n {print; exit}' "$INDEX")
[ -z "$rec" ] && exit 0
path=$(printf '%s' "$rec" | awk -F'\t' '{print $3}')

# for functions/aliases, path is "file:line" — split
file="${path%%:*}"
line=""
case "$path" in
  *:*) line="${path##*:}" ;;
esac

ED="${EDITOR:-nano}"
if [ -n "$line" ]; then
  # nano, vim, emacs, gedit all support +LINE for jump-to-line
  exec "$ED" "+${line}" "$file"
else
  exec "$ED" "$file"
fi
