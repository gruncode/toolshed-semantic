#!/bin/bash
# Renders a syntax-highlighted preview pane for the toolshed fuzzy picker
# Called by fzf as: toolshed-preview "<fzf row>"
# Part of the toolshed catalog toolkit

set -u

TOOLSHED_DIR="${TOOLSHED_DIR:-${HOME}/.local/share/toolshed}"
INDEX="$TOOLSHED_DIR/index.tsv"

# pick syntax-highlight tool
if command -v batcat >/dev/null 2>&1; then
  BAT=batcat
elif command -v bat >/dev/null 2>&1; then
  BAT=bat
else
  BAT=""
fi

row="${1:-}"
if [ -z "$row" ]; then
  echo "(no row)"
  exit 0
fi

# parse type (strip brackets) and name from the aligned fzf row
type=$(printf '%s' "$row" | awk '{print $1}' | tr -d '[]')
name=$(printf '%s' "$row" | awk '{print $2}')

# lookup full record in the TSV
rec=$(awk -F'\t' -v t="$type" -v n="$name" '$1==t && $2==n {print; exit}' "$INDEX")
if [ -z "$rec" ]; then
  printf '(no index record for %s/%s)\n' "$type" "$name"
  exit 0
fi

path=$(  printf '%s' "$rec" | awk -F'\t' '{print $3}')
cat=$(   printf '%s' "$rec" | awk -F'\t' '{print $4}')
desc=$(  printf '%s' "$rec" | awk -F'\t' '{print $5}')
mtime=$( printf '%s' "$rec" | awk -F'\t' '{print $6}')

# colored header
printf '\033[1;36m%s\033[0m  \033[2m[%s]\033[0m\n' "$name" "$type"
printf '\033[2m%s\033[0m\n' "$path"
printf '\033[33mcategory:\033[0m %s    \033[33mmodified:\033[0m %s\n' "$cat" "$mtime"
printf '\n%s\n' "$desc"
printf '\n\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m\n'

case "$type" in
  script)
    if [ ! -r "$path" ]; then
      echo "(file not readable)"
      exit 0
    fi
    if [ -n "$BAT" ]; then
      "$BAT" --color=always --style=numbers,changes --line-range=:80 --paging=never "$path" 2>/dev/null
    else
      head -80 "$path"
    fi
    ;;
  function)
    file=$(printf '%s' "$path" | cut -d: -f1)
    line=$(printf '%s' "$path" | cut -d: -f2)
    if [ -z "$line" ] || ! [ -r "$file" ]; then
      echo "(function source unreadable)"
      exit 0
    fi
    lo=$(( line > 2 ? line - 2 : 1 ))
    hi=$(( line + 30 ))
    if [ -n "$BAT" ]; then
      "$BAT" --color=always --style=numbers --highlight-line="$line" \
             --language=bash --line-range="${lo}:${hi}" --paging=never "$file" 2>/dev/null
    else
      sed -n "${lo},${hi}p" "$file" 2>/dev/null
    fi
    ;;
  alias)
    file=$(printf '%s' "$path" | cut -d: -f1)
    line=$(printf '%s' "$path" | cut -d: -f2)
    if [ -z "$line" ] || ! [ -r "$file" ]; then
      echo "(alias source unreadable)"
      exit 0
    fi
    lo=$(( line > 2 ? line - 2 : 1 ))
    hi=$(( line + 2 ))
    if [ -n "$BAT" ]; then
      "$BAT" --color=always --style=numbers --highlight-line="$line" \
             --language=bash --line-range="${lo}:${hi}" --paging=never "$file" 2>/dev/null
    else
      sed -n "${line}p" "$file" 2>/dev/null
    fi
    ;;
  *)
    echo "(unknown type: $type)"
    ;;
esac
