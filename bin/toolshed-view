#!/bin/bash
# Opens the full source of a gt catalog entry in a syntax-highlighted pager for reading
# Keywords: gt-view, full pager, source reader, batcat, less, code viewer, read source, mouse select
# gt-view — open the highlighted fzf row's file in a full-screen pager
# Called from gt via F3 binding
# Uses batcat (preferred, syntax-highlighted) or less as fallback
# Inside the pager, terminal's native mouse selection works for copying

set -u

INDEX="${HOME}/.local/share/mytools/index.tsv"
row="${1:-}"
[ -z "$row" ] && exit 0

type=$(printf '%s' "$row" | awk '{print $1}' | tr -d '[]')
name=$(printf '%s' "$row" | awk '{print $2}')
rec=$(awk -F'\t' -v t="$type" -v n="$name" '$1==t && $2==n {print; exit}' "$INDEX")
if [ -z "$rec" ]; then
  echo "(no record for $type/$name)"
  read -rp "press Enter..." _
  exit 0
fi

path=$(printf '%s' "$rec" | awk -F'\t' '{print $3}')
file="${path%%:*}"
line=""
case "$path" in
  *:*) line="${path##*:}" ;;
esac

if [ ! -r "$file" ]; then
  echo "(cannot read: $file)"
  read -rp "press Enter..." _
  exit 0
fi

# Prefer batcat (syntax highlight) — it uses less internally, so native mouse selection works
if command -v batcat >/dev/null 2>&1; then
  if [ -n "$line" ]; then
    batcat --paging=always --style=numbers,changes --highlight-line="$line" "$file"
  else
    batcat --paging=always --style=numbers,changes "$file"
  fi
elif command -v bat >/dev/null 2>&1; then
  if [ -n "$line" ]; then
    bat --paging=always --style=numbers,changes --highlight-line="$line" "$file"
  else
    bat --paging=always --style=numbers,changes "$file"
  fi
else
  if [ -n "$line" ]; then
    less -R "+${line}" "$file"
  else
    less -R "$file"
  fi
fi
