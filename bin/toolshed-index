#!/bin/bash
# Scans user bin dirs and bashrc to build the gt tool catalog index (index.tsv, CMDLIST.md, embeddings)
# Keywords: gt-index, catalog builder, index generator, tool scanner, script inventory, command list, embeddings, mytools, reindex, refresh
# toolshed-index — catalog your user-authored commands
# Scans bin dirs + /etc/bash.bashrc + ~/.bashrc, writes index.tsv and CMDLIST.md
# Regenerate anytime: `gt-index`
# Part of the `gt` catalog toolkit (see also: `gt`)

set -u

MYTOOLS_DIR="${HOME}/.local/share/mytools"
INDEX="$MYTOOLS_DIR/index.tsv"
CMDLIST="$MYTOOLS_DIR/CMDLIST.md"
CHANGELOG="$MYTOOLS_DIR/CHANGELOG.md"
BASHRC_USER="${HOME}/.bashrc"
BASHRC_SYS="/etc/bash.bashrc"

SCAN_DIRS=(
  "/usr/local/bin"
  "${HOME}/bin"
  "${HOME}/.local/bin"
  "${HOME}/scripts"
  "${HOME}/scripts/webautomations"
  "${HOME}/.npm-global/bin"
)

CLAUDE_CMDS_DIR="${HOME}/.claude/commands"

# Third-party binaries to exclude (not user-written)
THIRD_PARTY_RE='^(aws|aws_completer|copilot|duckdb|geckodriver|ollama|trash-restore|uv|uvx|odflint|odfmeta|odfoutline|odfimgimport|odfuserfield|odf2mht|odf2xhtml|odf2xml|mailodf|csv2ods|xml2odf|gcloud|claude)$'

# Backup-suffix pattern (case-insensitive)
BAK_RE='\.(bak|backup|tmp|orig|current-)|\.pre-|-bak-|-backup-|_before_|\.[0-9]{6,}_|\.[0-9]{8}-'

mkdir -p "$MYTOOLS_DIR"

# --------- helper: infer category from command name ---------
category_for() {
  case "$1" in
    dsearch|search-ai-*|split-query-*|recoll-search|docfetcher-search|faiss-search|his|hiso) echo search ;;
    lo|gf|gfr|gfd|losed|hi|rfind|ftx|showapt|showhistT|als|xstat) echo search ;;
    claude-*|store_claude_hist|extract-dead-context|explain-with-claude.sh|explain-with-codex.sh) echo claude ;;
    chrome-*|firefox-*) echo browser ;;
    scrape-*|scrape*|crawl*|cdp-*|web-auto-*) echo web-auto ;;
    copyq-*) echo clipboard ;;
    clip-sync-*|clipboard-*) echo clipboard ;;
    vnc-*|vbox-*|virtualbox-*|start-vm-*|monitor-vm-*) echo virt ;;
    pl|plc|pld) echo logs ;;
    backup-*) echo backup ;;
    *back|*backup) echo network ;;
    speak|readaloud) echo tts ;;
    gt|gt-index|gt-edit|gt-preview) echo catalog ;;
    gt-ai-*|gt-codex-*) echo ai-mcp ;;
    gt-custom-*) echo misc ;;
    gt-*) echo ai-mcp ;;
    cline|codex|firecrawl) echo ai-mcp ;;
    oomd-notify*) echo system ;;
    rm|nemo|cl|xfce4-terminal*) echo wrapper ;;
    heavy-run|fix-audio*|test-vaapi*|set-gaming-*|claude-voice) echo system ;;
    grep|lsa|gps|dmesg|ls|vgl|pyenv) echo general ;;
    # Add your SSH host aliases here, or use TOOLSHED_CATEGORIES_FILE in config
    # myserver|myrpi|mynas) echo ssh ;;
    # myserver@gw) echo ssh-gw ;;
    mount-*|u*|m[rg]*) echo mount ;;
    *) echo misc ;;
  esac
}

# --------- helper: extract 1-line description from script header ---------
# Parses first meaningful # comment (skips shebang, ===, ---, Keywords: lines)
# Falls back to Python """ docstring first non-decoration line if no # comment found
extract_desc() {
  local f="$1"
  local desc
  desc=$(head -20 "$f" 2>/dev/null | awk '
    NR==1 && /^#!/ { next }
    /^[[:space:]]*#[[:space:]]*=+/ { next }
    /^[[:space:]]*#[[:space:]]*-+/ { next }
    /^[[:space:]]*#[[:space:]]*[Kk]eywords?:/ { next }
    /^[[:space:]]*#/ {
      sub(/^[[:space:]]*#[[:space:]]*/, "")
      if (length($0) > 0) { print; exit }
    }
    !/^[[:space:]]*#/ && NR>1 { exit }
  ')
  if [ -n "$desc" ]; then
    printf '%s' "$desc"
    return
  fi
  # Fallback: Python triple-quote docstring — first non-empty, non-decoration line
  head -20 "$f" 2>/dev/null | awk '
    /^"""/ || /^'\'''\'''\''/ { in_doc=1; sub(/^"""|^'\'''\'''\''/, ""); if (length($0)>0 && $0 !~ /^=+$/ && $0 !~ /^-+$/) {print; exit}; next }
    in_doc && /^=+$/ { next }
    in_doc && /^-+$/ { next }
    in_doc && /^[[:space:]]*$/ { next }
    in_doc && (/^"""/||/^'\'''\'''\''/) { exit }
    in_doc { sub(/^[[:space:]]*/, ""); if (length($0)>0) {print; exit} }
  '
}

# --------- helper: extract Keywords: line from script header ---------
extract_keywords() {
  local f="$1"
  head -20 "$f" 2>/dev/null | sed -n 's/^[[:space:]]*#[[:space:]]*[Kk]eywords\?:[[:space:]]*//p' | head -1
}

# --------- helper: extract @mcp.tool functions from a Python file via AST ---------
extract_mcp_tools() {
  local pyfile="$1" server_id="$2"
  python3 -c "
import ast, sys
try:
    with open('$pyfile') as f:
        tree = ast.parse(f.read())
    for node in ast.walk(tree):
        if not isinstance(node, ast.FunctionDef):
            continue
        is_tool = any(
            (isinstance(d, ast.Attribute) and getattr(d, 'attr', '') == 'tool')
            or (isinstance(d, ast.Call) and isinstance(d.func, ast.Attribute) and getattr(d.func, 'attr', '') == 'tool')
            for d in node.decorator_list
        )
        if not is_tool:
            continue
        doc = ast.get_docstring(node) or ''
        first_line = doc.split(chr(10))[0].strip() if doc else ''
        if not first_line:
            first_line = '—'
        first_line = first_line.replace(chr(9), ' ')[:200]
        print(f'$server_id/{node.name}\t{first_line}')
except Exception as e:
    print(f'# parse error: {e}', file=sys.stderr)
" 2>/dev/null
}

# --------- scan scripts ---------
TMP_TSV=$(mktemp)
trap "rm -f '$TMP_TSV'" EXIT

printf 'type\tname\tpath\tcategory\tdescription\tmtime\tkeywords\n' > "$TMP_TSV"

count_scripts=0
declare -A seen_inode   # dedupe symlinks pointing to same file

for d in "${SCAN_DIRS[@]}"; do
  [ -d "$d" ] || continue
  while IFS= read -r -d '' f; do
    base=$(basename "$f")

    # skip backup files
    echo "$base" | grep -qiE "$BAK_RE" && continue

    # skip third-party
    echo "$base" | grep -qE "$THIRD_PARTY_RE" && continue

    # skip dpkg-owned
    rp=$(readlink -f "$f" 2>/dev/null || echo "$f")
    dpkg -S "$rp" >/dev/null 2>&1 && continue
    dpkg -S "$f" >/dev/null 2>&1 && continue

    # skip broken symlinks (target does not exist)
    if [ ! -e "$rp" ]; then
      continue
    fi

    # dedupe by resolved inode (handles symlinks)
    inode=$(stat -c '%i:%d' "$rp" 2>/dev/null)
    if [ -n "$inode" ]; then
      if [ -n "${seen_inode[$inode]:-}" ]; then
        continue
      fi
      seen_inode["$inode"]=1
    fi

    desc=$(extract_desc "$f")
    [ -z "$desc" ] && desc="—"
    desc=$(printf '%s' "$desc" | tr '\t\n' '  ' | cut -c1-200)

    kw=$(extract_keywords "$f")
    kw=$(printf '%s' "$kw" | tr '\t\n' '  ' | cut -c1-300)

    mtime=$(stat -c '%y' "$f" 2>/dev/null | cut -d' ' -f1)
    cat=$(category_for "$base")

    printf 'script\t%s\t%s\t%s\t%s\t%s\t%s\n' "$base" "$f" "$cat" "$desc" "$mtime" "$kw" >> "$TMP_TSV"
    count_scripts=$((count_scripts + 1))
  done < <(find "$d" -maxdepth 1 \( -type f -o -type l \) -print0 2>/dev/null)
done

# --------- parse shell functions from /etc/bash.bashrc ---------
if [ -r "$BASHRC_SYS" ]; then
  while IFS=: read -r line_no func_name; do
    [ -z "$func_name" ] && continue
    # grab description: next line that is a comment, or line before function def
    desc=$(sed -n "$((line_no + 1)),$((line_no + 5))p" "$BASHRC_SYS" 2>/dev/null | grep -E '^[[:space:]]*#' | head -1 | sed 's/^[[:space:]]*#[[:space:]]*//')
    [ -z "$desc" ] && desc=$(sed -n "$((line_no - 3)),$((line_no - 1))p" "$BASHRC_SYS" 2>/dev/null | grep -E '^[[:space:]]*#' | tail -1 | sed 's/^[[:space:]]*#[[:space:]]*//')
    [ -z "$desc" ] && desc="(function in $BASHRC_SYS)"
    desc=$(printf '%s' "$desc" | tr '\t\n' '  ' | cut -c1-200)
    cat=$(category_for "$func_name")
    printf 'function\t%s\t%s:%s\t%s\t%s\t—\t\n' "$func_name" "$BASHRC_SYS" "$line_no" "$cat" "$desc" >> "$TMP_TSV"
  done < <(awk '/^[A-Za-z_][A-Za-z0-9_-]*[[:space:]]*\(\)/ {name=$1; sub(/\(\).*/,"",name); print NR ":" name}' "$BASHRC_SYS")
fi
count_funcs=$(awk -F'\t' '$1=="function"' "$TMP_TSV" | wc -l)

# --------- parse aliases from both bashrc files ---------
for f in "$BASHRC_USER" "$BASHRC_SYS"; do
  [ -r "$f" ] || continue
  grep -nE '^[[:space:]]*alias[[:space:]]+[A-Za-z_@][A-Za-z0-9_@-]*=' "$f" 2>/dev/null | \
  while IFS=: read -r line_no rest; do
    name=$(printf '%s' "$rest" | sed -E 's/^[[:space:]]*alias[[:space:]]+([A-Za-z_@][A-Za-z0-9_@-]*)=.*/\1/')
    expansion=$(printf '%s' "$rest" | sed -E "s/^[[:space:]]*alias[[:space:]]+[A-Za-z_@][A-Za-z0-9_@-]*=//; s/^['\"]//; s/['\"][[:space:]]*#?.*$//; s/^'//; s/'$//")
    expansion=$(printf '%s' "$expansion" | tr '\t\n' '  ' | cut -c1-200)
    cat=$(category_for "$name")
    printf 'alias\t%s\t%s:%s\t%s\t%s\t—\t\n' "$name" "$f" "$line_no" "$cat" "$expansion" >> "$TMP_TSV"
  done
done
count_aliases=$(awk -F'\t' '$1=="alias"' "$TMP_TSV" | wc -l)

# --------- scan Claude Code slash commands (~/.claude/commands/*.md) ---------
count_skills=0
if [ -d "$CLAUDE_CMDS_DIR" ]; then
  for f in "$CLAUDE_CMDS_DIR"/*.md; do
    [ -f "$f" ] || continue
    base=$(basename "$f" .md)
    # extract first non-empty, non-heading line as description
    desc=$(grep -v '^$' "$f" | grep -v '^#' | head -1 | cut -c1-200)
    [ -z "$desc" ] && desc="Claude Code slash command"
    desc=$(printf '%s' "$desc" | tr '\t\n' '  ')
    mtime=$(stat -c '%y' "$f" 2>/dev/null | cut -d' ' -f1)
    printf 'skill\t/%s\t%s\t%s\t%s\t%s\t\n' "$base" "$f" "claude" "$desc" "$mtime" >> "$TMP_TSV"
    count_skills=$((count_skills + 1))
  done
fi

# --------- scan MCP servers ---------
# Sources: ~/.local/share/mcp/*/ + paths from ~/.mcp.json & ~/.claude/mcp.json
count_mcp=0
MCP_ROOT="${HOME}/.local/share/mcp"
declare -A seen_mcp_dir   # dedupe server dirs from multiple sources

# Collect all MCP server directories
MCP_DIRS=()

# Source 1: standard MCP_ROOT subdirs
if [ -d "$MCP_ROOT" ]; then
  while IFS= read -r d; do
    MCP_DIRS+=("$d")
  done < <(find "$MCP_ROOT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
fi

# Source 2: extract server dirs from .mcp.json and ~/.claude/mcp.json
for mcpjson in "${HOME}/.mcp.json" "${HOME}/.claude/mcp.json"; do
  [ -f "$mcpjson" ] || continue
  while IFS= read -r extra_dir; do
    [ -z "$extra_dir" ] && continue
    # Only add if not already under MCP_ROOT (avoid duplicates)
    case "$extra_dir" in
      "${MCP_ROOT}/"*) ;;
      *) MCP_DIRS+=("$extra_dir") ;;
    esac
  done < <(python3 -c "
import json, os, sys
with open('$mcpjson') as f:
    cfg = json.load(f)
for name, srv in cfg.get('mcpServers', {}).items():
    args = srv.get('args', [])
    cmd = srv.get('command', '')
    for a in args:
        a = str(a)
        if '/' in a and os.path.exists(a):
            p = os.path.realpath(a)
            d = os.path.dirname(p) if os.path.isfile(p) else p
            print(d)
            break
    else:
        if '/' in cmd and os.path.exists(cmd):
            p = os.path.realpath(cmd)
            d = os.path.dirname(p) if os.path.isfile(p) else p
            print(d)
" 2>/dev/null)
done

for server_dir in "${MCP_DIRS[@]}"; do
  # dedupe by resolved path
  rsd=$(readlink -f "$server_dir" 2>/dev/null || echo "$server_dir")
  [ -n "${seen_mcp_dir[$rsd]:-}" ] && continue
  seen_mcp_dir["$rsd"]=1

  pyproj="$server_dir/pyproject.toml"
  readme="$server_dir/README.md"

  # Extract project name and description from pyproject.toml
  proj_name=""
  proj_desc=""
  if [ -f "$pyproj" ]; then
    proj_name=$(sed -n '/^\[project\]/,/^\[/{/^[[:space:]]*name[[:space:]]*=/s/^[^=]*=[[:space:]]*["'"'"']\?\([^"'"'"']*\).*/\1/p}' "$pyproj" | head -1)
    proj_desc=$(sed -n '/^\[project\]/,/^\[/{/^[[:space:]]*description[[:space:]]*=/s/^[^=]*=[[:space:]]*["'"'"']\?\([^"'"'"']*\).*/\1/p}' "$pyproj" | head -1)
  fi
  [ -z "$proj_name" ] && proj_name=$(basename "$server_dir")
  [ -z "$proj_desc" ] && [ -f "$readme" ] && proj_desc=$(grep -v '^[[:space:]]*$' "$readme" | grep -v '^#' | head -1)
  [ -z "$proj_desc" ] && proj_desc="MCP server"
  proj_desc=$(printf '%s' "$proj_desc" | tr '\t\n' '  ' | cut -c1-200)

  server_id=$(printf '%s' "$proj_name" | tr '[:upper:] ' '[:lower:]-' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+|-+$//g')
  mtime=$(stat -c '%y' "${pyproj:-$server_dir}" 2>/dev/null | cut -d' ' -f1)

  # Add server-level row
  printf 'mcp-server\t%s\t%s\t%s\t%s\t%s\t\n' "$server_id" "$server_dir" "ai-mcp" "$proj_desc" "$mtime" >> "$TMP_TSV"

  # Extract @mcp.tool functions from Python files
  # Search: src/**/tools.py + root *.py + bin/*.py (covers all layouts)
  declare -A seen_pyfile
  while IFS= read -r -d '' tools_py; do
    rpf=$(readlink -f "$tools_py" 2>/dev/null || echo "$tools_py")
    [ -n "${seen_pyfile[$rpf]:-}" ] && continue
    seen_pyfile["$rpf"]=1

    # Skip venv site-packages (never contains user tools)
    case "$rpf" in */site-packages/*) continue ;; esac

    tmtime=$(stat -c '%y' "$tools_py" 2>/dev/null | cut -d' ' -f1)
    extract_mcp_tools "$tools_py" "$server_id" | while IFS=$'\t' read -r tool_name tool_desc; do
      printf 'mcp-tool\t%s\t%s\t%s\t%s\t%s\t\n' "$tool_name" "$tools_py" "ai-mcp" "$tool_desc" "$tmtime" >> "$TMP_TSV"
    done
  done < <(
    find "$server_dir/src" -maxdepth 3 -type f -name '*.py' -print0 2>/dev/null
    find "$server_dir" -maxdepth 1 -type f -name '*.py' -print0 2>/dev/null
    find "$server_dir/bin" -maxdepth 1 -type f -name '*.py' -print0 2>/dev/null
  )
  unset seen_pyfile

  # Also index standalone executable scripts in MCP dirs (e.g. bulk_ocr_gemini.py)
  # These are user scripts co-located with MCP servers but not @mcp.tool-decorated
  declare -A mcp_tool_files  # files already indexed as mcp-tool sources
  while IFS=$'\t' read -r _t _n tf _rest; do
    [ "$_t" = "mcp-tool" ] && mcp_tool_files["$tf"]=1
  done < "$TMP_TSV"

  while IFS= read -r -d '' sf; do
    base=$(basename "$sf")

    # skip backup files
    echo "$base" | grep -qiE "$BAK_RE" && continue

    # skip non-Python/non-shell (e.g. .txt, .json)
    case "$base" in *.py|*.sh) ;; *) continue ;; esac

    # skip if not executable
    [ -x "$sf" ] || continue

    # skip if already indexed as mcp-tool source
    rsf=$(readlink -f "$sf" 2>/dev/null || echo "$sf")
    [ -n "${mcp_tool_files[$rsf]:-}" ] && continue
    [ -n "${mcp_tool_files[$sf]:-}" ] && continue

    # skip if already indexed as a script (by name, from SCAN_DIRS)
    awk -F'\t' '$1=="script" && $2=="'"$base"'" {found=1; exit} END {exit !found}' "$TMP_TSV" 2>/dev/null && continue

    desc=$(extract_desc "$sf")
    [ -z "$desc" ] && desc="—"
    desc=$(printf '%s' "$desc" | tr '\t\n' '  ' | cut -c1-200)
    smtime=$(stat -c '%y' "$sf" 2>/dev/null | cut -d' ' -f1)
    cat=$(category_for "$base")

    kw=$(extract_keywords "$sf")
    kw=$(printf '%s' "$kw" | tr '\t\n' '  ' | cut -c1-300)
    printf 'script\t%s\t%s\t%s\t%s\t%s\t%s\n' "$base" "$sf" "$cat" "$desc" "$smtime" "$kw" >> "$TMP_TSV"
    count_scripts=$((count_scripts + 1))
  done < <(find "$server_dir" -maxdepth 1 -type f \( -name '*.py' -o -name '*.sh' \) -print0 2>/dev/null)
done
# --------- discover cloud/plugin MCP tools from Claude session logs ---------
# These tools have no local code but are used via Claude (Gmail, GCal, Brightdata, etc.)
SESSIONS_DIR="${TOOLSHED_CLAUDE_SESSIONS:-$(ls -d "${HOME}/.claude/projects/"*/ 2>/dev/null | head -1)}"
if [ -d "$SESSIONS_DIR" ]; then
  # Collect already-known mcp-tool names to skip
  declare -A known_mcp_tools
  while IFS=$'\t' read -r _t _n _rest; do
    [ "$_t" = "mcp-tool" ] && known_mcp_tools["$_n"]=1
  done < "$TMP_TSV"

  # Scan sessions from last 60 days, extract mcp__ tool names, count usage
  find "$SESSIONS_DIR" -name '*.jsonl' -mtime -60 -print0 2>/dev/null | \
    xargs -0 grep -oh '"name":"mcp__[^"]*"' 2>/dev/null | \
    sed 's/"name":"//; s/"//' | sort | uniq -c | sort -rn | \
  while read -r usage_count raw_name; do
    [ -z "$raw_name" ] && continue
    [ "$usage_count" -lt 2 ] && continue  # skip one-offs

    # Parse: mcp__claude_ai_Gmail__gmail_search → server=Gmail tool=gmail_search kind=cloud
    #        mcp__plugin_playwright_playwright__browser_click → server=playwright tool=browser_click kind=plugin
    #        mcp__voicemode__converse → server=voicemode tool=converse kind=local
    short=""
    kind=""
    rest="${raw_name#mcp__}"
    if [[ "$rest" =~ ^claude_ai_(.+)__(.+)$ ]]; then
      srv="${BASH_REMATCH[1]}"
      tool="${BASH_REMATCH[2]}"
      short="$srv/$tool"
      kind="cloud"
    elif [[ "$rest" =~ ^plugin_[^_]+_([^_]+)__(.+)$ ]]; then
      srv="${BASH_REMATCH[1]}"
      tool="${BASH_REMATCH[2]}"
      short="$srv/$tool"
      kind="plugin"
    elif [[ "$rest" =~ ^([^_]+)__(.+)$ ]]; then
      srv="${BASH_REMATCH[1]}"
      tool="${BASH_REMATCH[2]}"
      short="$srv/$tool"
      kind="local"
    else
      continue
    fi

    # Skip if already indexed locally
    [ -n "${known_mcp_tools[$short]:-}" ] && continue

    # For local servers, check if the server is already indexed (tools might exist)
    if [ "$kind" = "local" ]; then
      # Only add if the server IS indexed but this specific tool wasn't found locally
      awk -F'\t' -v s="$srv" '$1=="mcp-server" && $2==s {found=1; exit} END {exit !found}' "$TMP_TSV" 2>/dev/null || continue
    fi

    # Humanize description from tool name
    desc=$(echo "$tool" | tr '_' ' ')
    [ "$kind" != "local" ] && desc="$desc ($kind)"

    printf 'mcp-tool\t%s\t%s\t%s\t%s\t—\t\n' "$short" "($kind)" "ai-mcp" "$desc" >> "$TMP_TSV"
    known_mcp_tools["$short"]=1
  done
fi

count_mcp=$(awk -F'\t' '$1=="mcp-tool" || $1=="mcp-server"' "$TMP_TSV" | wc -l)

# --------- scan systemd services (user-created) ---------
count_services=0
SVC_SYSTEM="/etc/systemd/system"
SVC_USER="${HOME}/.config/systemd/user"

for svc_dir in "$SVC_SYSTEM" "$SVC_USER"; do
  [ -d "$svc_dir" ] || continue
  for svc_file in "$svc_dir"/*.service; do
    [ -f "$svc_file" ] || continue
    svc_base=$(basename "$svc_file" .service)

    # skip dpkg-owned (standard system services)
    dpkg -S "$svc_file" >/dev/null 2>&1 && continue

    # skip dbus aliases and target-wants symlinks
    [ -L "$svc_file" ] && continue

    # skip backup files
    echo "$svc_base" | grep -qiE "$BAK_RE" && continue

    # extract Description= from the unit file
    svc_desc=$(grep -m1 "^Description=" "$svc_file" 2>/dev/null | sed "s/^Description=//")
    [ -z "$svc_desc" ] && svc_desc="systemd service"
    svc_desc=$(printf "%s" "$svc_desc" | tr "\t\n" "  " | cut -c1-200)

    # extract ExecStart= to find the main executable
    svc_exec=$(grep -m1 "^ExecStart=" "$svc_file" 2>/dev/null | sed "s/^ExecStart=//" | awk "{print \$1}" | sed "s/^-//")

    # keywords from Description + ExecStart path
    svc_kw="systemd service $svc_base"
    [ -n "$svc_exec" ] && svc_kw="$svc_kw $(basename "$svc_exec" 2>/dev/null)"
    [ "$svc_dir" = "$SVC_USER" ] && svc_kw="$svc_kw user" || svc_kw="$svc_kw system"

    svc_mtime=$(stat -c "%y" "$svc_file" 2>/dev/null | cut -d" " -f1)
    svc_cat=$(category_for "$svc_base")

    printf "service\t%s\t%s\t%s\t%s\t%s\t%s\n" "$svc_base" "$svc_file" "$svc_cat" "$svc_desc" "$svc_mtime" "$svc_kw" >> "$TMP_TSV"
    count_services=$((count_services + 1))
  done
done

# --------- write outputs ---------
cp "$TMP_TSV" "$INDEX"
chmod 644 "$INDEX"

{
  echo "# $(whoami)'s tool catalog"
  echo
  echo "_Generated $(date '+%Y-%m-%d %H:%M:%S') by \`gt-index\` on $(hostname)_"
  echo
  echo "**Totals:** $count_scripts scripts + $count_funcs functions + $count_aliases aliases + $count_skills skills + $count_services services + $count_mcp mcp = **$((count_scripts + count_funcs + count_aliases + count_skills + count_services + count_mcp))** commands"
  echo
  echo "- Regenerate: \`gt-index\`"
  echo "- Search interactively: \`gt\`"
  echo "- Filter by category: \`gt --list <category>\`"
  echo

  for type in script function alias skill service mcp-server mcp-tool; do
    type_label=$(echo "$type" | sed 's/.*/\u&s/')
    echo "## $type_label"
    echo
    # sort by category, then name
    awk -F'\t' -v t="$type" '$1==t' "$INDEX" | sort -t$'\t' -k4,4 -k2,2 > /tmp/gt-md-tmp.$$
    prev_cat=""
    while IFS=$'\t' read -r T name path cat desc mtime; do
      if [ "$cat" != "$prev_cat" ]; then
        [ -n "$prev_cat" ] && echo
        echo "### $cat"
        echo
        prev_cat="$cat"
      fi
      # escape pipes in description for markdown
      d=$(printf '%s' "$desc" | sed 's/|/\\|/g')
      echo "- \`$name\` — $d"
      echo "  \`$path\`"
    done < /tmp/gt-md-tmp.$$
    rm -f /tmp/gt-md-tmp.$$
    echo
  done
} > "$CMDLIST"

{
  echo "$(date '+%Y-%m-%d %H:%M:%S')  scripts=$count_scripts  functions=$count_funcs  aliases=$count_aliases  skills=$count_skills  services=$count_services  mcp=$count_mcp  total=$((count_scripts + count_funcs + count_aliases + count_skills + count_services + count_mcp))"
} >> "$CHANGELOG"

# --------- build Cohere embedding cache (inside a subshell — secrets stay local) ---------
emb_status="skipped"
EMBED_PY="${TOOLSHED_EMBED_PYTHON:-python3}"
if [ -n "${COHERE_API_KEY:-}" ] && "$EMBED_PY" -c "import cohere, numpy" 2>/dev/null; then
  if (
    [ -n "${COHERE_API_KEY:-}" ] || exit 1
    export GTI_INDEX="$INDEX"
    export GTI_OUT="$MYTOOLS_DIR/embeddings.npz"
    "$EMBED_PY" - << 'PYEOF' 2>&1
import os, sys
import numpy as np
import cohere

idx = os.environ['GTI_INDEX']
out = os.environ['GTI_OUT']

rows = []
with open(idx) as f:
    header = f.readline()  # skip header
    for line in f:
        parts = line.rstrip('\n').split('\t')
        if len(parts) >= 5:
            # Ensure 7 columns (pad with empty if old format)
            while len(parts) < 7:
                parts.append('')
            rows.append(parts)

if not rows:
    print("  embeddings: no rows to index", file=sys.stderr)
    sys.exit(0)

# Build the text each row is embedded as — for aliases/functions, REPLACE the
# raw bash expansion with a clean semantic sentence so shell noise tokens
# (like $pherpc, allow_other, reconnect) don't dominate the embedding.
import re as _re

def _extract_ssh_host(expansion, alias_name):
    m = _re.search(r'@(\S+?)(?:\s|:|$)', expansion)
    if m:
        return m.group(1).rstrip(':')
    parts = expansion.split()
    for i, p in enumerate(parts):
        if p == 'ssh' and i + 1 < len(parts) and not parts[i+1].startswith('-'):
            return parts[i+1]
    return alias_name

def _extract_sshfs_target(expansion, alias_name):
    m = _re.search(r'/home/PCs/([A-Za-z0-9_-]+)', expansion)
    return m.group(1) if m else alias_name

def enrich(t, name, cat, desc, keywords=''):
    d = (desc or "").strip()
    dl = d.lower()
    n = name.lower()
    kw_suffix = f" — keywords: {keywords}" if keywords and keywords.strip() else ""

    if t == "alias":
        if dl.startswith("ssh ") and "sshfs" not in dl:
            host = _extract_ssh_host(d, name)
            return (f"alias {name} connect ssh remote login interactive shell session "
                    f"to host {host} machine pc computer server via ssh protocol terminal "
                    f"remote access login")
        if "autossh" in dl:
            host = _extract_ssh_host(d, name)
            return (f"alias {name} autossh persistent ssh tunnel auto-reconnect connect "
                    f"to remote host {host} machine pc computer stable connection")
        if "sshfs" in dl:
            target = _extract_sshfs_target(d, name)
            host = _extract_ssh_host(d, name)
            return (f"alias {name} sshfs mount remote filesystem as network drive share "
                    f"from host {host} to local /home/PCs/{target} network filesystem mount")
        if dl.startswith("umount") or " umount" in dl:
            target = _extract_sshfs_target(d, name)
            return (f"alias {name} unmount dismount filesystem /home/PCs/{target} "
                    f"network drive release")
        if dl.startswith("mount ") and "cifs" in dl:
            return (f"alias {name} mount cifs samba windows network share filesystem "
                    f"from remote host")
        if dl.startswith("mount "):
            return f"alias {name} mount filesystem local bind directory"
        if dl.startswith("locate"):
            return f"alias {name} locate fast file search plocate database by filename"
        if "ps -eo" in dl or dl.startswith("ps "):
            return f"alias {name} ps process list running processes by user cpu memory"
        if dl.startswith("ls "):
            return f"alias {name} ls directory listing files color human readable"
        if dl.startswith("grep"):
            return f"alias {name} grep text search pattern in files color highlight"
        if "dmesg" in dl:
            return f"alias {name} dmesg kernel log messages human readable timestamps"
        if "vglrun" in dl:
            return f"alias {name} virtualgl vglrun gpu graphics 3d accelerated opengl"
        if "source" in dl and "venv" in dl:
            return f"alias {name} python venv virtualenv activate environment pyenv"
        # fallback: use raw but tag it
        return f"alias {name} ({cat}) {d}"

    if t == "function":
        if "find" in n or n in ("gf", "gfr", "gfd", "rfind", "losed"):
            return (f"function {name} file search find locate filesystem by name "
                    f"filename recursive directory")
        if n == "hi":
            return f"function {name} bash history search grep past commands"
        if "xstat" in n:
            return (f"function {name} file stat metadata creation time crtime ctime "
                    f"inode debugfs filesystem")
        if "showapt" in n:
            return f"function {name} apt package install history log show commandline"
        if "showhist" in n or "showhistT" == n:
            return f"function {name} bash history timestamped formatted show past"
        if "als" in n:
            return f"function {name} ls alias paginated directory listing files human"
        if "ftx" in n:
            return (f"function {name} text grep recursive pattern search in files "
                    f"by extension")
        return f"function {name} ({cat}) {d if d and d != '—' else name}"

    if t == "skill":
        return (f"skill slash command {name} Claude Code custom command "
                f"({cat}) {d if d and d != '—' else name}")

    if t == "mcp-server":
        shown = d if d and d != "—" else name
        return (f"MCP server {name} model context protocol service integration "
                f"({cat}) {shown}")

    if t == "mcp-tool":
        parts = name.split("/", 1)
        server = parts[0] if parts else "server"
        tool = parts[1] if len(parts) > 1 else name
        shown = d if d and d != "—" else tool
        # Find server description to enrich tool embedding
        srv_desc = ""
        for sr in rows:
            if sr[0] == "mcp-server" and sr[1] == server:
                srv_desc = sr[4] if sr[4] and sr[4] != "—" else ""
                break
        ctx = f" {srv_desc}" if srv_desc else ""
        return (f"mcp tool {tool} from MCP server {server}{ctx} model context protocol "
                f"API integration ({cat}) {shown}")

    if t == "service":
        scope = "user" if "user" in (keywords or "") else "system"
        shown = d if d and d != "—" else name
        return (f"systemd service unit {name} {scope} daemon background process "
                f"({cat}) {shown}{kw_suffix}")

    # scripts: header comment + keywords for embedding richness
    shown = d if d and d != "—" else name
    return f"script {name} ({cat}) {shown}{kw_suffix}"

texts = [enrich(r[0], r[1], r[3], r[4], r[6] if len(r) > 6 else '') for r in rows]
keys  = [f"{r[0]}:{r[1]}" for r in rows]

co = cohere.ClientV2(api_key=os.environ['COHERE_API_KEY'])
vecs = []
# batch in chunks of 96 (Cohere v3 max)
for i in range(0, len(texts), 96):
    r = co.embed(
        texts=texts[i:i + 96],
        model='embed-multilingual-v3.0',
        input_type='search_document',
        embedding_types=['float'],
    )
    vecs.extend(r.embeddings.float_)

V = np.array(vecs, dtype=np.float32)
norms = np.linalg.norm(V, axis=1, keepdims=True)
V = V / np.where(norms > 0, norms, 1.0)
np.savez_compressed(out, vectors=V, keys=np.array(keys))
print(f"  embeddings: {V.shape[0]} rows × {V.shape[1]}-dim -> {out}")
PYEOF
  ); then
    emb_status="ok"
  else
    emb_status="failed (key missing or API error)"
  fi
fi

echo "catalog written to $MYTOOLS_DIR"
echo "  scripts   : $count_scripts"
echo "  functions : $count_funcs"
echo "  aliases   : $count_aliases"
echo "  skills    : $count_skills"
echo "  mcp       : $count_mcp"
echo "  services  : $count_services"
echo "  total     : $((count_scripts + count_funcs + count_aliases + count_skills + count_services + count_mcp))"
echo "  index     : $INDEX"
echo "  markdown  : $CMDLIST"
echo "  NL search : $emb_status"
